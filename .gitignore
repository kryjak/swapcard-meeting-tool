# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# embedding cache + dumped profile batches (large, regenerable, derived from public sheet)
/cache/

# generated recommendation output (personal data)
/output/*
!/output/.gitkeep

# swapcard availability export (personal data, refresh before each scheduler run)
my_availability.json

# manual busy intervals (personal schedule data)
manual_busy.json

# requester context (personal goals and extra context)
requester_context.json

# legacy timeslot_optimisation folder — contains only personal data files
timeslot_optimisation/

# python cache
__pycache__/
*.pyc
*.pyo
