# ── Sheet / event identity ────────────────────────────────────────────────────

# Google Sheet containing attendee profiles.
# Default is EAG London 2026 — change for other events.
# To find this data, go to your event on Swapcard, find something like 'Attendee data sheet', and look for similar strings in the URL of the Google Sheet
SHEET_ID=1Uvj0sDZzQJN0gUsccpw0HAf5qjFB6pkbjGMt2QuH6RA
SHEET_GID=43679916

# ── STAGE 1: LLM recommendation engine ───────────────────────────────────────

# Provider: anthropic | gemini | openai
LLM_PROVIDER=anthropic

# Model override (leave blank to use the provider default below)
#   anthropic default: claude-sonnet-4-6   (mid-tier; use claude-opus-4-7 for max quality)
#   gemini    default: gemini-2.5-flash    (mid-tier; use gemini-2.5-pro for max quality)
#   openai    default: gpt-5.5             (mid-tier; use gpt-5.5-pro for max quality)
LLM_MODEL=

# API keys — set only the one for your chosen provider
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# How many recommendations to aim for (default 25)
NUM_RECOMMENDATIONS=25

# Retrieval pool sizes (usually no need to change)
RECALL_TOP=150
RECALL_TOP_LATERAL=40

# Output directory for generated .md files (default: output/)
OUTPUT_DIR=output

# ── STAGE 2: Swapcard meeting scheduler ──────────────────────────────────────

# Bearer JWT from Swapcard browser session — expires ~24h, refresh before each run.
# How to get: open Swapcard in browser → DevTools (F12) → Network tab →
#   click any request → Headers → copy the Authorization header value (without "Bearer ").
SWAPCARD_TOKEN=

# Event ID (base64-encoded Swapcard event ID).
# Default is EAG London 2026 — change for other events.
EVENT_ID=RXZlbnRfNDQzNjA4NQ==

# Conference date window (ISO 8601 with timezone offset)
DATE_RANGE_START=2026-05-29T00:00:00+01:00
DATE_RANGE_END=2026-06-01T23:59:59+01:00

# Candidates table generated by recommend.py — edit this file between stages.
# Point to a specific dated file if you have multiple runs.
CANDIDATES_FILE=output/meeting_candidates_latest.md

# Your Swapcard agenda export (network capture — see README for how to export).
MY_AVAILABILITY_FILE=my_availability.json

# Relevance scores to include in the schedule (comma-separated, no spaces).
RANKINGS_TO_CONSIDER=4,5

# Your Swapcard agenda export — blocks your talks, meetups, and outgoing meeting
# requests so the scheduler doesn't double-book you. See README for how to export.
# Note: the Swapcard API filters candidate slots by your outgoing pending meeting
# requests automatically, but NOT by your full calendar (talks, meetups) — hence
# this file is still needed for sessions you attend.
MY_AVAILABILITY_FILE=my_availability.json

# Additional busy intervals for things outside Swapcard (travel, meals, etc.)
# Copy manual_busy.example.json → manual_busy.json and edit it (it's gitignored).
MANUAL_BUSY_FILE=manual_busy.json

# Insert a 25-minute buffer between meetings when possible.
# Gaps are added as a post-processing step and never cause a meeting to be dropped.
# Priority is given to gaps after rating-5 meetings.
PREFER_MEETING_GAP=true
